# AutoPulse Environment Variables Blueprint Template
# Copy this file to a local .env file and update with real credentials

# Core Infrastructure Details
ENVIRONMENT=production
SUPABASE_URL=https://lfjyktuirksclrvujmvz.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY_HERE

# System Webhooks & APIs
ORACLE_API_BASE=https://api.internal.autopulse.dev
ORACLE_API_TOKEN=YOUR_ORACLE_API_TOKEN_HERE
WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

# Heavy Compute Fallback Engines
OCI_ENGINE_URL=http://140.245.226.112:8080
CLOUD_RUN_URL=http://140.245.226.112:8080

# NVIDIA NIM Multi-Key Rotation Pool
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1
